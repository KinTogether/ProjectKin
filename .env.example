# ============================================================
# Kin -- Local environment template
# ------------------------------------------------------------
# Copy to `.env` and fill in. Never commit `.env`.
# ============================================================

# ---- App ----
APP_ENV=development                 # development | staging | production
APP_LOG_LEVEL=info                  # debug | info | warn | error

# ---- Supabase (self-hosted, local) ----
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me-keep-secret
SUPABASE_JWT_SECRET=replace-me-min-32-chars

# ---- Postgres (used by Supabase stack) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kin
POSTGRES_USER=kin
POSTGRES_PASSWORD=change-me-locally

# ---- Auth ----
PHONE_HASH_SALT=replace-me-random-32-bytes-base64
OTP_TTL_SECONDS=300
OTP_MAX_PER_PHONE_PER_HOUR=3

# ---- Storage ----
STORAGE_BUCKET=kin-media
MEDIA_CLIENT_ENCRYPTION=true        # never disable in production

# ---- Mobile (Flutter) ----
KIN_API_BASE_URL=http://localhost:54321
KIN_REALTIME_URL=ws://localhost:54321/realtime/v1
